# Health MCP server config. Add these lines to the SAME mcp/.env you use for
# PepBros (it is gitignored). HEALTH_* values fall back to the PEPBROS_* ones
# because it is the same Supabase project — so if mcp/.env already has the
# PepBros config, the health server needs NOTHING extra and reads the same
# user. Set HEALTH_* only if you want to override.

# Same project + service_role key as PepBros (Supabase → Settings → API).
# HEALTH_SUPABASE_URL=https://mxcpjsdvdqhgutdzzggo.supabase.co
# HEALTH_SUPABASE_SERVICE_KEY=your-service-role-key-here

# The account whose health data to expose. Falls back to PEPBROS_USER_EMAIL.
# The server REFUSES to start without a user scope (multi-user DB safety).
# HEALTH_USER_EMAIL=jsmc88@gmail.com
# HEALTH_USER_ID=

# ── Edge Function secrets (NOT used by this Node server) ──────────────────────
# Set these on the Supabase Edge Function instead (supabase secrets set ...).
# The phone sends this exact string as "Authorization: Bearer <secret>".
# HEALTH_INGEST_SECRET=generate-a-long-random-string
# The user_id the ingest function writes rows for (same id as above).
# HEALTH_INGEST_USER_ID=
