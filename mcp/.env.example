# Copy to .env and fill in. NEVER commit .env (it holds a full-access secret).
PEPBROS_SUPABASE_URL=https://mxcpjsdvdqhgutdzzggo.supabase.co
# Supabase → Settings → API → "service_role" secret (NOT the publishable/anon key).
PEPBROS_SUPABASE_SERVICE_KEY=your-service-role-key-here
# REQUIRED (multi-user DB): the account whose data to expose. Resolved to a
# user_id at startup. The server REFUSES to start without a user scope, so it can
# never accidentally return other household members' peptides.
PEPBROS_USER_EMAIL=jsmc88@gmail.com
# Optional: set PEPBROS_USER_ID directly to skip the email→id lookup.
# PEPBROS_USER_ID=
